---
import SiteBrand from "../../components/SiteBrand.astro";
import { rewriteRootLinks, withBase } from "../../lib/sitePaths";

type ExerciseMarkdown = {
  compiledContent: () => Promise<string>;
  frontmatter: {
    title: string;
    alternateFor?: string[];
  };
};

const exerciseModules = import.meta.glob<ExerciseMarkdown>(
  "../../content/warmups/exercises/**/*.md",
  { eager: true },
);
const uniqueBySlug = new Map<string, ExerciseMarkdown>();
for (const [path, exercise] of Object.entries(exerciseModules).sort(([a], [b]) => a.localeCompare(b))) {
  const slug = path.split(/[\\/]/).pop()?.replace(/\.md$/, "") ?? "";
  if (!uniqueBySlug.has(slug)) uniqueBySlug.set(slug, exercise);
}
const exercises = await Promise.all(
  Array.from(uniqueBySlug.entries()).map(async ([slug, exercise]) => {
    const alternates = Array.from(uniqueBySlug.entries())
      .filter(([, mod]) => mod.frontmatter.alternateFor?.includes(slug))
      .map(([altSlug, mod]) => ({ slug: altSlug, title: mod.frontmatter.title }))
      .sort((a, b) => a.title.localeCompare(b.title));
    const modificationFor = (exercise.frontmatter.alternateFor ?? [])
      .map((primarySlug) => ({ slug: primarySlug, title: uniqueBySlug.get(primarySlug)?.frontmatter.title ?? primarySlug }))
      .sort((a, b) => a.title.localeCompare(b.title));

    return {
      slug,
      title: exercise.frontmatter.title,
      html: rewriteRootLinks(await exercise.compiledContent()),
      alternates,
      modificationFor,
    };
  }),
);
exercises.sort((a, b) => a.title.localeCompare(b.title));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Alphabetical exercise and stretch instructions for karate warm-up routines."
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href={withBase("/styles/print.css")} />
    <title>Exercise Instructions</title>
  </head>
  <body>
    <main>
      <SiteBrand />

      <header class="page-header">
        <p class="eyebrow">Instruction reference</p>
        <h1>Exercise Instructions</h1>
        <p class="lede">
          Reusable exercise and stretch instructions used across the warm-up routines.
        </p>
      </header>

      <section class="exercise-list">
        {
          exercises.map((exercise) => (
            <article class="exercise-entry" id={exercise.slug}>
              <h2>
                <a href={withBase(`/exercises/${exercise.slug}/`)}>{exercise.title}</a>
              </h2>
              {exercise.modificationFor.length > 0 && (
                <p class="modification-badge">
                  <sup class="alt-marker">⇄</sup> Modification for:{" "}
                  {exercise.modificationFor.map((primary, i) => (
                    <>
                      {i > 0 && ", "}
                      <a href={withBase(`/exercises/${primary.slug}/`)}>{primary.title}</a>
                    </>
                  ))}
                </p>
              )}
              <Fragment set:html={exercise.html} />
              {exercise.alternates.length > 0 && (
                <>
                  <h3>Alternates</h3>
                  <ul>
                    {exercise.alternates.map((alt) => (
                      <li><a href={withBase(`/exercises/${alt.slug}/`)}>{alt.title}</a></li>
                    ))}
                  </ul>
                </>
              )}
            </article>
          ))
        }
      </section>

      <nav class="bottom-nav no-print" aria-label="Back to overview">
        <a href={withBase("/")}>Back to overview</a>
        <a href="#">Back to top</a>
      </nav>
    </main>
  </body>
</html>
