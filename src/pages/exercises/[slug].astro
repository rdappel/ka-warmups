---
import SiteBrand from "../../components/SiteBrand.astro";
import { rewriteRootLinks, withBase } from "../../lib/sitePaths";

type ExerciseMarkdown = {
  default: unknown;
  compiledContent: () => Promise<string>;
  frontmatter: {
    title: string;
    alternateFor?: string[];
  };
};

export async function getStaticPaths() {
  const exerciseModules = import.meta.glob<ExerciseMarkdown>(
    "../../content/warmups/exercises/**/*.md",
    { eager: true },
  );

  const slugs = new Set(
    Object.keys(exerciseModules).map((path) => path.split(/[\\/]/).pop()?.replace(/\.md$/, "") ?? ""),
  );

  return Array.from(slugs)
    .sort()
    .map((slug) => ({
      params: { slug },
      props: { slug },
    }));
}

const { slug } = Astro.props;
const exerciseModules = import.meta.glob<ExerciseMarkdown>(
  "../../content/warmups/exercises/**/*.md",
  { eager: true },
);
const exerciseEntry = Object.entries(exerciseModules).find(
  ([path]) => path.split(/[\\/]/).pop() === `${slug}.md`,
);
const exercise = exerciseEntry![1];
const exerciseHtml = rewriteRootLinks(await exercise.compiledContent());

const bySlug = new Map<string, ExerciseMarkdown>();
for (const [path, mod] of Object.entries(exerciseModules)) {
  const otherSlug = path.split(/[\\/]/).pop()?.replace(/\.md$/, "") ?? "";
  if (!bySlug.has(otherSlug)) bySlug.set(otherSlug, mod);
}
const alternates = Array.from(bySlug.entries())
  .filter(([, mod]) => mod.frontmatter.alternateFor?.includes(slug))
  .map(([altSlug, mod]) => ({ slug: altSlug, title: mod.frontmatter.title }))
  .sort((a, b) => a.title.localeCompare(b.title));
const modificationFor = (exercise.frontmatter.alternateFor ?? [])
  .map((primarySlug) => ({ slug: primarySlug, title: bySlug.get(primarySlug)?.frontmatter.title ?? primarySlug }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${exercise.frontmatter.title} instructions`} />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href={withBase("/styles/print.css")} />
    <title>{exercise.frontmatter.title}</title>
  </head>
  <body>
    <main>
      <SiteBrand />

      <header class="page-header">
        <p class="eyebrow">Exercise instruction</p>
        <h1>{exercise.frontmatter.title}</h1>
        {modificationFor.length > 0 && (
          <p class="modification-badge">
            <sup class="alt-marker">⇄</sup> Modification for:{" "}
            {modificationFor.map((primary, i) => (
              <>
                {i > 0 && ", "}
                <a href={withBase(`/exercises/${primary.slug}/`)}>{primary.title}</a>
              </>
            ))}
          </p>
        )}
      </header>

      <article class="exercise-detail">
        <Fragment set:html={exerciseHtml} />
        {alternates.length > 0 && (
          <>
            <h2>Alternates</h2>
            <ul>
              {alternates.map((alt) => (
                <li><a href={withBase(`/exercises/${alt.slug}/`)}>{alt.title}</a></li>
              ))}
            </ul>
          </>
        )}
      </article>

      <nav class="bottom-nav no-print" aria-label="Exercise navigation">
        <a href={withBase("/exercises/")}>All exercise instructions</a>
        <a href={withBase("/")}>Back to overview</a>
        <a href="#">Back to top</a>
      </nav>
    </main>
  </body>
</html>
