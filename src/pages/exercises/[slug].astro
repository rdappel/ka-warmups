---
import SiteBrand from "../../components/SiteBrand.astro";

type ExerciseMarkdown = {
  default: unknown;
  frontmatter: {
    title: string;
  };
};

export async function getStaticPaths() {
  const exerciseModules = import.meta.glob<ExerciseMarkdown>(
    "../../content/warmups/exercises/*.md",
    { eager: true },
  );

  return Object.keys(exerciseModules)
    .map((path) => path.split(/[\\/]/).pop()?.replace(/\.md$/, "") ?? "")
    .sort()
    .map((slug) => ({
      params: { slug },
      props: { slug },
    }));
}

const { slug } = Astro.props;
const exerciseModules = import.meta.glob<ExerciseMarkdown>(
  "../../content/warmups/exercises/*.md",
  { eager: true },
);
const exercise = exerciseModules[`../../content/warmups/exercises/${slug}.md`];
const Content = exercise.default;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${exercise.frontmatter.title} instructions`} />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="/styles/print.css" />
    <title>{exercise.frontmatter.title}</title>
  </head>
  <body>
    <main>
      <SiteBrand />

      <header class="page-header">
        <p class="eyebrow">Exercise instruction</p>
        <h1>{exercise.frontmatter.title}</h1>
      </header>

      <article class="exercise-detail">
        <Content />
      </article>

      <nav class="bottom-nav no-print" aria-label="Exercise navigation">
        <a href="/exercises/">All exercise instructions</a>
        <a href="/">Back to overview</a>
      </nav>
    </main>
  </body>
</html>
